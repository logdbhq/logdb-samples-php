# Copy this file to `.env` and fill in your LogDB API key.

# Required: account-scoped API key from the LogDB dashboard.
LOGDB_API_KEY=your-api-key-here

# Optional: defaults to https://otlp.logdb.site
LOGDB_ENDPOINT=https://test-01.logdb.site/otlp

# Optional: REST API base for the Reader (used by the Browse screens).
# Defaults to https://test-01.logdb.site/rest-api. SDK appends /log/sdk/* paths.
LOGDB_READER_ENDPOINT=https://test-01.logdb.site/rest-api

# Stamped on every log as the `application` field.
LOGDB_APPLICATION=logdb-php-sample

# Stamped as `environment`. Defaults to "development" in this sample.
LOGDB_ENVIRONMENT=development
