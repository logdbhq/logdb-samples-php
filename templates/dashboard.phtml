                        'NotAuthorized' => 'error',
                        'CircuitOpen', 'Timeout' => 'warning',
                        default => 'error',
                    };
                    ?>
                    <tr>
                        <td class="col-mono"><?= $view->e(date('H:i:s', (int) ($r['ts'] / 1000))) ?></td>
                        <td><?= $view->e($r['type']) ?></td>
                        <td><span class="level-badge <?= $statusBadge ?>"><?= $view->e($r['status']) ?></span></td>
                        <td><?= $view->e($r['summary']) ?><?php if ($r['error'] !== null): ?> <span class="muted">— <?= $view->e($r['error']) ?></span><?php endif; ?></td>
